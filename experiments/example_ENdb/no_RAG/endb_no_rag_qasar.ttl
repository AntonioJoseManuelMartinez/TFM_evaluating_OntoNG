@prefix base: <http://example.com/ontoNG#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dc11: <http://purl.org/dc/elements/1.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

base: a owl:Ontology ;
  dc11:title "Enhancer Regulatory Feature Ontology" ;
  dcterms:description "An ontology describing enhancers, genes, tissues, diseases, transcription factors, and regulatory features derived from structured data and an ER model." ;
  owl:versionInfo "0.0.1" ;
  vann:preferredNamespaceUri "http://example.com/ontoNG#" ;
  vann:preferredNamespacePrefix "onto_ng" ;
  owl:versionIRI <http://example.com/ontoNG#0.0.1> .

base:enhancerId a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "enhancerId" ;
  skos:definition "A unique identifier for an enhancer. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:string .

base:chromosome a owl:DatatypeProperty ;
  rdfs:label "chromosome" ;
  skos:definition "The chromosome on which an enhancer is located. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:string .

base:startPosition a owl:DatatypeProperty ;
  rdfs:label "startPosition" ;
  skos:definition "The genomic start position of an enhancer. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:integer .

base:endPosition a owl:DatatypeProperty ;
  rdfs:label "endPosition" ;
  skos:definition "The genomic end position of an enhancer. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:integer .

base:enhancerType a owl:DatatypeProperty ;
  rdfs:label "enhancerType" ;
  skos:definition "A type designation for an enhancer or regulatory feature. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:string .

base:targetGene a owl:DatatypeProperty , owl:FunctionalProperty ;
  rdfs:label "targetGene" ;
  skos:definition "The identifier or name of a target gene. (Generated by AI)" ;
  rdfs:domain base:Gene ;
  rdfs:range xsd:string .

base:tissueContext a owl:DatatypeProperty ;
  rdfs:label "tissueContext" ;
  skos:definition "The tissue context in which a regulatory feature occurs. (Generated by AI)" ;
  rdfs:domain base:Tissue ;
  rdfs:range xsd:string .

base:diseaseName a owl:DatatypeProperty ;
  rdfs:label "diseaseName" ;
  skos:definition "The name of a disease associated with a regulatory feature. (Generated by AI)" ;
  rdfs:domain base:Disease ;
  rdfs:range xsd:string .

base:transcriptionFactor a owl:DatatypeProperty ;
  rdfs:label "transcriptionFactor" ;
  skos:definition "The name of a transcription factor involved in a regulatory feature. (Generated by AI)" ;
  rdfs:domain base:TranscriptionFactor ;
  rdfs:range xsd:string .

base:targets a owl:ObjectProperty ;
  rdfs:label "targets" ;
  skos:definition "Relates an enhancer to the gene it targets. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range base:Gene .

base:characterizes a owl:ObjectProperty ;
  rdfs:label "characterizes" ;
  skos:definition "Relates an enhancer to a regulatory feature that characterizes it. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range base:RegulatoryFeature .

base:occursIn a owl:ObjectProperty ;
  rdfs:label "occurs_in" ;
  skos:definition "Relates a tissue to a regulatory feature occurring in that tissue context. (Generated by AI)" ;
  rdfs:domain base:Tissue ;
  rdfs:range base:RegulatoryFeature .

base:associatedWith a owl:ObjectProperty ;
  rdfs:label "associated_with" ;
  skos:definition "Relates a disease to a regulatory feature associated with that disease. (Generated by AI)" ;
  rdfs:domain base:Disease ;
  rdfs:range base:RegulatoryFeature .

base:involves a owl:ObjectProperty ;
  rdfs:label "involves" ;
  skos:definition "Relates a transcription factor to a regulatory feature that involves it. (Generated by AI)" ;
  rdfs:domain base:TranscriptionFactor ;
  rdfs:range base:RegulatoryFeature .

base:Enhancer a owl:Class ;
  rdfs:label "Enhancer" ;
  skos:definition "A genomic enhancer element with a defined location, identifier, type, and target gene relationship. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:enhancerId ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:chromosome ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:startPosition ;
      owl:someValuesFrom xsd:integer
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:endPosition ;
      owl:someValuesFrom xsd:integer
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:enhancerType ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:targets ;
      owl:someValuesFrom base:Gene
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:characterizes ;
      owl:someValuesFrom base:RegulatoryFeature
    ] .

base:Gene a owl:Class ;
  rdfs:label "Gene" ;
  skos:definition "A gene that is targeted by an enhancer. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:targetGene ;
      owl:someValuesFrom xsd:string
    ] .

base:Tissue a owl:Class ;
  rdfs:label "Tissue" ;
  skos:definition "A tissue context in which a regulatory feature occurs. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:tissueContext ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:occursIn ;
      owl:someValuesFrom base:RegulatoryFeature
    ] .

base:Disease a owl:Class ;
  rdfs:label "Disease" ;
  skos:definition "A disease associated with a regulatory feature. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:diseaseName ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:associatedWith ;
      owl:someValuesFrom base:RegulatoryFeature
    ] .

base:TranscriptionFactor a owl:Class ;
  rdfs:label "TranscriptionFactor" ;
  skos:definition "A transcription factor involved in a regulatory feature. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:transcriptionFactor ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:involves ;
      owl:someValuesFrom base:RegulatoryFeature
    ] .

base:RegulatoryFeature a owl:Class ;
  rdfs:label "RegulatoryFeature" ;
  skos:definition "A regulatory feature characterized by enhancer type, tissue context, disease association, and transcription factor involvement. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:enhancerType ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:tissueContext ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:diseaseName ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:transcriptionFactor ;
      owl:someValuesFrom xsd:string
    ] .