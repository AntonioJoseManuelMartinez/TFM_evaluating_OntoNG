@prefix base: <http://example.com/featurevector-regulatory-ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gomo: <https://ontology.basf.net/ontology/BASF/Core/GomoMetadata/> .
@prefix term: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix element: <http://purl.org/dc/elements/1.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sio: <http://semanticscience.org/resource/> .
@prefix ncit: <http://purl.obolibrary.org/obo/> .
@prefix so: <http://purl.obolibrary.org/obo/> .

base:FeatureVectorRegulatoryOntology rdf:type owl:Ontology ;
    element:title "feature vector regulatory ontology" ;
    term:description "An ontology for enhancer-centered regulatory associations connecting tissue context, disease, gene, and transcription factor features derived from a conceptual data model and structured feature vector schema. (Generated by AI)" ;
    element:creator "None (user@email.com)" ;
    term:created "2026-04-29" ;
    term:issued "2026-04-29" ;
    owl:versionInfo "0.0.1" ;
    vann:preferredNamespaceUri "http://example.com/featurevector-regulatory-ontology#" ;
    vann:preferredNamespacePrefix "feature_vector_regulatory_ontology" ;
    owl:versionIRI <http://example.com/featurevector-regulatory-ontology#0.0.1> .

base:chromosome rdf:type owl:DatatypeProperty ;
    rdfs:label "chromosome" ;
    skos:definition "Chromosomal identifier associated with an enhancer. (Generated by AI)" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:string .

base:diseaseName rdf:type owl:DatatypeProperty ;
    rdfs:label "disease name" ;
    skos:definition "Name of a disease represented in the feature vector and regulatory association model. (Generated by AI)" ;
    rdfs:domain base:Disease ;
    rdfs:range xsd:string .

base:enhancerId rdf:type owl:DatatypeProperty ;
    rdfs:label "enhancer id" ;
    skos:definition "Identifier assigned to an enhancer. (Generated by AI)" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:string .

base:enhancerType rdf:type owl:DatatypeProperty ;
    rdfs:label "enhancer type" ;
    skos:definition "Type or category assigned to an enhancer. (Generated by AI)" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:string .

base:endPosition rdf:type owl:DatatypeProperty ;
    rdfs:label "end position" ;
    skos:definition "Genomic end coordinate of an enhancer. (Generated by AI)" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:integer .

base:startPosition rdf:type owl:DatatypeProperty ;
    rdfs:label "start position" ;
    skos:definition "Genomic start coordinate of an enhancer. (Generated by AI)" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:integer .

base:targetGene rdf:type owl:DatatypeProperty ;
    rdfs:label "target gene" ;
    skos:definition "Name or identifier of a target gene represented in the feature vector and regulatory association model. (Generated by AI)" ;
    rdfs:domain sio:SIO_010035 ;
    rdfs:range xsd:string .

base:tissueContext rdf:type owl:DatatypeProperty ;
    rdfs:label "tissue context" ;
    skos:definition "Name of a tissue or biological context represented in the feature vector and regulatory association model. (Generated by AI)" ;
    rdfs:domain base:TissueContext ;
    rdfs:range xsd:string .

base:transcriptionFactor rdf:type owl:DatatypeProperty ;
    rdfs:label "transcription factor" ;
    skos:definition "Name or identifier of a transcription factor represented in the feature vector and regulatory association model. (Generated by AI)" ;
    rdfs:domain ncit:C17207 ;
    rdfs:range xsd:string .

base:associatedWith rdf:type owl:ObjectProperty ;
    rdfs:label "associated with" ;
    skos:definition "Relates a regulatory association to a disease with which it is associated. (Generated by AI)" ;
    rdfs:domain so:SO_0000727 ;
    rdfs:range base:Disease .

base:hasTarget rdf:type owl:ObjectProperty ;
    rdfs:label "has target" ;
    skos:definition "Relates a regulatory association to a target gene. (Generated by AI)" ;
    rdfs:domain so:SO_0000727 ;
    rdfs:range sio:SIO_010035 .

base:involves rdf:type owl:ObjectProperty ;
    rdfs:label "involves" ;
    skos:definition "Relates a regulatory association to an enhancer involved in the association. (Generated by AI)" ;
    rdfs:domain so:SO_0000727 ;
    rdfs:range base:Enhancer .

base:occursIn rdf:type owl:ObjectProperty ;
    rdfs:label "occurs in" ;
    skos:definition "Relates a regulatory association to the tissue context in which it occurs. (Generated by AI)" ;
    rdfs:domain so:SO_0000727 ;
    rdfs:range base:TissueContext .

base:regulatedBy rdf:type owl:ObjectProperty ;
    rdfs:label "regulated by" ;
    skos:definition "Relates a regulatory association to a transcription factor that regulates it. (Generated by AI)" ;
    rdfs:domain so:SO_0000727 ;
    rdfs:range ncit:C17207 .

base:Disease rdf:type owl:Class ;
    rdfs:label "disease" ;
    skos:definition "A disease entity used to characterize a regulatory association within a feature vector context. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:diseaseName ;
            owl:someValuesFrom xsd:string
        ] .

base:Enhancer rdf:type owl:Class ;
    rdfs:label "enhancer" ;
    skos:definition "A genomic regulatory element characterized by genomic coordinates, identifier, and enhancer type. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:chromosome ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:enhancerId ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:enhancerType ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:endPosition ;
            owl:someValuesFrom xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:startPosition ;
            owl:someValuesFrom xsd:integer
        ] .

sio:SIO_010035 rdf:type owl:Class ;
    rdfs:label "gene" ;
    skos:definition "A gene that serves as a target in a regulatory association and feature vector. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:targetGene ;
            owl:someValuesFrom xsd:string
        ] .

base:TissueContext rdf:type owl:Class ;
    rdfs:label "tissue context" ;
    skos:definition "A tissue or biological context in which a regulatory association occurs. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:tissueContext ;
            owl:someValuesFrom xsd:string
        ] .

ncit:C17207 rdf:type owl:Class ;
    rdfs:label "transcription factor" ;
    skos:definition "A transcription factor participating in regulation represented by a regulatory association and feature vector. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:transcriptionFactor ;
            owl:someValuesFrom xsd:string
        ] .

so:SO_0000727 rdf:type owl:Class ;
    rdfs:label "regulatory association" ;
    skos:definition "A composite regulatory relation linking tissue context, disease, gene, transcription factor, and enhancer within a feature vector model. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:associatedWith ;
            owl:someValuesFrom base:Disease
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:hasTarget ;
            owl:someValuesFrom sio:SIO_010035
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:involves ;
            owl:someValuesFrom base:Enhancer
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:occursIn ;
            owl:someValuesFrom base:TissueContext
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:regulatedBy ;
            owl:someValuesFrom ncit:C17207
        ] .