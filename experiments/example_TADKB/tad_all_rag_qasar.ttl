@prefix base: <http://example.com/tad-observation-ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gomo: <https://ontology.basf.net/ontology/BASF/Core/GomoMetadata/> .
@prefix term: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix element: <http://purl.org/dc/elements/1.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix obo: <http://purl.obolibrary.org/obo/> .

base:tadObservationOntology rdf:type owl:Ontology ;
    element:title "tad observation ontology" ;
    term:description "An ontology describing topologically associating domains and their observations across source methods, cell types, calling methods, resolutions, source files, and databases. (Generated by AI)" ;
    element:creator "None (user@email.com)" ;
    term:created "2026-04-23"^^xsd:date ;
    term:issued "2026-04-23"^^xsd:date ;
    owl:versionInfo "0.0.1" ;
    vann:preferredNamespaceUri "http://example.com/tad-observation-ontology#" ;
    vann:preferredNamespacePrefix "tad_observation_ontology" ;
    owl:versionIRI <http://example.com/tad-observation-ontology#0.0.1> .

base:tadId rdf:type owl:DatatypeProperty ;
    rdfs:label "tad id" ;
    skos:definition "Identifier for a topologically associating domain. (Generated by AI)" ;
    rdfs:domain obo:SO_0002304 ;
    rdfs:range xsd:string .

base:chromosome rdf:type owl:DatatypeProperty ;
    rdfs:label "chromosome" ;
    skos:definition "Chromosome on which a topologically associating domain is located. (Generated by AI)" ;
    rdfs:domain obo:SO_0002304 ;
    rdfs:range xsd:string .

base:startPosition rdf:type owl:DatatypeProperty ;
    rdfs:label "start position" ;
    skos:definition "Genomic start position of a topologically associating domain. (Generated by AI)" ;
    rdfs:domain obo:SO_0002304 ;
    rdfs:range xsd:integer .

base:endPosition rdf:type owl:DatatypeProperty ;
    rdfs:label "end position" ;
    skos:definition "Genomic end position of a topologically associating domain. (Generated by AI)" ;
    rdfs:domain obo:SO_0002304 ;
    rdfs:range xsd:integer .

base:sourceMethodValue rdf:type owl:DatatypeProperty ;
    rdfs:label "source method value" ;
    skos:definition "Literal value naming a source method. (Generated by AI)" ;
    rdfs:domain base:SourceMethod ;
    rdfs:range xsd:string .

base:cellTypeValue rdf:type owl:DatatypeProperty ;
    rdfs:label "cell type value" ;
    skos:definition "Literal value naming a cell type. (Generated by AI)" ;
    rdfs:domain base:CellType ;
    rdfs:range xsd:string .

base:callingMethodValue rdf:type owl:DatatypeProperty ;
    rdfs:label "calling method value" ;
    skos:definition "Literal value naming a calling method. (Generated by AI)" ;
    rdfs:domain base:CallingMethod ;
    rdfs:range xsd:string .

base:resolutionValue rdf:type owl:DatatypeProperty ;
    rdfs:label "resolution value" ;
    skos:definition "Literal value specifying a resolution. (Generated by AI)" ;
    rdfs:domain base:Resolution ;
    rdfs:range xsd:string .

base:sourceFileValue rdf:type owl:DatatypeProperty ;
    rdfs:label "source file value" ;
    skos:definition "Literal value naming a source file. (Generated by AI)" ;
    rdfs:domain base:SourceFile ;
    rdfs:range xsd:string .

base:databaseName rdf:type owl:DatatypeProperty ;
    rdfs:label "database name" ;
    skos:definition "Literal value naming a database. (Generated by AI)" ;
    rdfs:domain obo:NCIT_C15426 ;
    rdfs:range xsd:string .

base:observedAs rdf:type owl:ObjectProperty ;
    rdfs:label "observed as" ;
    skos:definition "Relates a topologically associating domain to an observation record in which it is observed. (Generated by AI)" ;
    rdfs:domain obo:SO_0002304 ;
    rdfs:range <http://rdf.biogateway.eu/tad//tad_id> .

base:derivedFrom rdf:type owl:ObjectProperty ;
    rdfs:label "derived from" ;
    skos:definition "Relates an observation record to the source method from which it is derived. (Generated by AI)" ;
    rdfs:domain <http://rdf.biogateway.eu/tad//tad_id> ;
    rdfs:range base:SourceMethod .

base:identifiedIn rdf:type owl:ObjectProperty ;
    rdfs:label "identified in" ;
    skos:definition "Relates an observation record to the cell type in which it was identified. (Generated by AI)" ;
    rdfs:domain <http://rdf.biogateway.eu/tad//tad_id> ;
    rdfs:range base:CellType .

base:calledBy rdf:type owl:ObjectProperty ;
    rdfs:label "called by" ;
    skos:definition "Relates an observation record to the calling method used to define it. (Generated by AI)" ;
    rdfs:domain <http://rdf.biogateway.eu/tad//tad_id> ;
    rdfs:range base:CallingMethod .

base:measuredAt rdf:type owl:ObjectProperty ;
    rdfs:label "measured at" ;
    skos:definition "Relates an observation record to the resolution at which it was measured. (Generated by AI)" ;
    rdfs:domain <http://rdf.biogateway.eu/tad//tad_id> ;
    rdfs:range base:Resolution .

base:recordedIn rdf:type owl:ObjectProperty ;
    rdfs:label "recorded in" ;
    skos:definition "Relates an observation record to the source file in which it was recorded. (Generated by AI)" ;
    rdfs:domain <http://rdf.biogateway.eu/tad//tad_id> ;
    rdfs:range base:SourceFile .

base:storedIn rdf:type owl:ObjectProperty ;
    rdfs:label "stored in" ;
    skos:definition "Relates an observation record to the database in which it is stored. (Generated by AI)" ;
    rdfs:domain <http://rdf.biogateway.eu/tad//tad_id> ;
    rdfs:range obo:NCIT_C15426 .

obo:SO_0002304 rdf:type owl:Class ;
    rdfs:label "tad" ;
    skos:definition "A topologically associating domain represented with genomic coordinates and an identifier. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:tadId ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:chromosome ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:startPosition ;
            owl:someValuesFrom xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:endPosition ;
            owl:someValuesFrom xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:observedAs ;
            owl:someValuesFrom <http://rdf.biogateway.eu/tad//tad_id>
        ] .

base:SourceMethod rdf:type owl:Class ;
    rdfs:label "source method" ;
    skos:definition "A method describing the source by which a topologically associating domain observation was obtained. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:sourceMethodValue ;
            owl:someValuesFrom xsd:string
        ] .

base:CellType rdf:type owl:Class ;
    rdfs:label "cell type" ;
    skos:definition "A cell type in which a topologically associating domain observation is identified. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:cellTypeValue ;
            owl:someValuesFrom xsd:string
        ] .

base:CallingMethod rdf:type owl:Class ;
    rdfs:label "calling method" ;
    skos:definition "A computational or analytical method used to call a topologically associating domain observation. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:callingMethodValue ;
            owl:someValuesFrom xsd:string
        ] .

base:Resolution rdf:type owl:Class ;
    rdfs:label "resolution" ;
    skos:definition "A measurement resolution associated with a topologically associating domain observation. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:resolutionValue ;
            owl:someValuesFrom xsd:string
        ] .

base:SourceFile rdf:type owl:Class ;
    rdfs:label "source file" ;
    skos:definition "A source file in which a topologically associating domain observation is recorded. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:sourceFileValue ;
            owl:someValuesFrom xsd:string
        ] .

obo:NCIT_C15426 rdf:type owl:Class ;
    rdfs:label "database" ;
    skos:definition "A database in which a topologically associating domain observation is stored. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:databaseName ;
            owl:someValuesFrom xsd:string
        ] .

<http://rdf.biogateway.eu/tad//tad_id> rdf:type owl:Class ;
    rdfs:label "tad observation" ;
    skos:definition "An observation record linking a topologically associating domain to source method, cell type, calling method, resolution, source file, and database context. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:derivedFrom ;
            owl:someValuesFrom base:SourceMethod
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:identifiedIn ;
            owl:someValuesFrom base:CellType
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:calledBy ;
            owl:someValuesFrom base:CallingMethod
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:measuredAt ;
            owl:someValuesFrom base:Resolution
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:recordedIn ;
            owl:someValuesFrom base:SourceFile
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:storedIn ;
            owl:someValuesFrom obo:NCIT_C15426
        ] .