@prefix base: <http://example.com/ontoNG#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gomo: <https://ontology.basf.net/ontology/BASF/Core/GomoMetadata/> .
@prefix term: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix element: <http://purl.org/dc/elements/1.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sio: <http://semanticscience.org/resource/> .
@prefix schema: <https://schema.org/> .

base:EnhancerFeatureOntology rdf:type owl:Ontology ;
    element:title "enhancer feature ontology" ;
    term:description "An ontology describing enhancers, genes, diseases, and their associations derived from a conceptual data model and structured feature data. (Generated by AI)" ;
    element:creator "None (user@email.com)" ;
    term:created "2026-04-26"^^xsd:date ;
    term:issued "2026-04-26"^^xsd:date ;
    owl:versionInfo "0.0.1" ;
    vann:preferredNamespaceUri "http://example.com/ontoNG#" ;
    vann:preferredNamespacePrefix "enhancer_feature_ontology" ;
    owl:versionIRI <http://example.com/ontoNG#0.0.1> .

base:associatedGene rdf:type owl:DatatypeProperty ;
    rdfs:label "associated gene" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:string ;
    skos:definition "A gene identifier associated with an enhancer as represented in the structured source data. (Generated by AI)" .

base:chromosome rdf:type owl:DatatypeProperty ;
    rdfs:label "chromosome" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:string ;
    rdfs:seeAlso schema:chromosome ;
    skos:definition "The chromosome on which an enhancer is located. (Generated by AI)" .

base:diseaseName rdf:type owl:DatatypeProperty ;
    rdfs:label "disease name" ;
    rdfs:domain base:Disease ;
    rdfs:range xsd:string ;
    skos:definition "The name identifying a disease entity. (Generated by AI)" .

base:endPosition rdf:type owl:DatatypeProperty ;
    rdfs:label "end position" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:float ;
    skos:definition "The genomic end position of an enhancer region. (Generated by AI)" .

base:enhancerId rdf:type owl:DatatypeProperty ;
    rdfs:label "enhancer id" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:string ;
    skos:definition "A string identifier that uniquely identifies an enhancer. (Generated by AI)" .

base:startPosition rdf:type owl:DatatypeProperty ;
    rdfs:label "start position" ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:float ;
    skos:definition "The genomic start position of an enhancer region. (Generated by AI)" .

base:associatedWithDisease rdf:type owl:ObjectProperty ;
    rdfs:label "associated with disease" ;
    rdfs:domain base:Enhancer ;
    rdfs:range base:Disease ;
    skos:definition "Relates an enhancer to a disease with which it is associated. (Generated by AI)" .

base:associatedWithGene rdf:type owl:ObjectProperty ;
    rdfs:label "associated with gene" ;
    rdfs:domain base:Enhancer ;
    rdfs:range sio:SIO_010035 ;
    skos:definition "Relates an enhancer to a gene with which it is associated. (Generated by AI)" .

base:Disease rdf:type owl:Class ;
    rdfs:label "disease" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:diseaseName ;
            owl:someValuesFrom xsd:string
        ] ;
    rdfs:seeAlso schema:MedicalCondition ;
    skos:definition "A disease entity that may be associated with an enhancer. (Generated by AI)" .

base:Enhancer rdf:type owl:Class ;
    rdfs:label "enhancer" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:associatedGene ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:associatedWithDisease ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass base:Disease
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:associatedWithGene ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass sio:SIO_010035
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:chromosome ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:endPosition ;
            owl:someValuesFrom xsd:float
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:enhancerId ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:startPosition ;
            owl:someValuesFrom xsd:float
        ] ;
    rdfs:seeAlso schema:BioChemEntity ;
    skos:definition "A genomic enhancer feature characterized by identifier, chromosome, start position, end position, and optional associations to a gene and a disease. (Generated by AI)" .

sio:SIO_010035 rdf:type owl:Class ;
    rdfs:label "gene" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:associatedWithGene ;
            owl:inverseOf base:associatedWithGene
        ] ;
    skos:definition "A gene entity associated with an enhancer. (Generated by AI)" .