@prefix base: <http://example.com/ontoNG#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dc11: <http://purl.org/dc/elements/1.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

base: a owl:Ontology ;
  dc:title "Enhancer Gene Disease Ontology" ;
  dcterms:description "An ontology describing enhancers, genes, diseases, and their associated genomic feature attributes derived from structured data and an ER model." ;
  owl:versionInfo "0.0.1" ;
  vann:preferredNamespaceUri "http://example.com/ontoNG#" ;
  vann:preferredNamespacePrefix "onto_ng" ;
  owl:versionIRI <http://example.com/ontoNG#0.0.1> .

base:enhancerId a owl:DatatypeProperty, owl:FunctionalProperty ;
  rdfs:label "enhancerId" ;
  skos:definition "A unique identifier for an enhancer. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:string .

base:chromosome a owl:DatatypeProperty ;
  rdfs:label "chromosome" ;
  skos:definition "The chromosome on which an enhancer is located. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:string .

base:startPosition a owl:DatatypeProperty ;
  rdfs:label "startPosition" ;
  skos:definition "The start genomic position of an enhancer. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:float .

base:endPosition a owl:DatatypeProperty ;
  rdfs:label "endPosition" ;
  skos:definition "The end genomic position of an enhancer. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:float .

base:associatedGene a owl:DatatypeProperty, owl:FunctionalProperty ;
  rdfs:label "associatedGene" ;
  skos:definition "A unique identifier or name for a gene associated with an enhancer. (Generated by AI)" ;
  rdfs:domain base:Gene ;
  rdfs:range xsd:string .

base:diseaseName a owl:DatatypeProperty, owl:FunctionalProperty ;
  rdfs:label "diseaseName" ;
  skos:definition "A unique name identifying a disease linked to an enhancer. (Generated by AI)" ;
  rdfs:domain base:Disease ;
  rdfs:range xsd:string .

base:associatedWith a owl:ObjectProperty ;
  rdfs:label "associatedWith" ;
  skos:definition "Relates an enhancer to the gene with which it is associated. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range base:Gene .

base:linkedTo a owl:ObjectProperty ;
  rdfs:label "linkedTo" ;
  skos:definition "Relates an enhancer to the disease to which it is linked. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range base:Disease .

base:Enhancer a owl:Class ;
  rdfs:label "Enhancer" ;
  skos:definition "A genomic enhancer region characterized by an identifier, chromosome, and genomic coordinates, and linked to a gene and a disease. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:enhancerId ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:chromosome ;
      owl:someValuesFrom xsd:string
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:startPosition ;
      owl:someValuesFrom xsd:float
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:endPosition ;
      owl:someValuesFrom xsd:float
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:associatedWith ;
      owl:someValuesFrom base:Gene
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty base:linkedTo ;
      owl:someValuesFrom base:Disease
    ] .

base:Gene a owl:Class ;
  rdfs:label "Gene" ;
  skos:definition "A gene that is associated with one or more enhancers. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:associatedGene ;
      owl:someValuesFrom xsd:string
    ] .

base:Disease a owl:Class ;
  rdfs:label "Disease" ;
  skos:definition "A disease linked to one or more enhancers. (Generated by AI)" ;
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty base:diseaseName ;
      owl:someValuesFrom xsd:string
    ] .