@prefix base: <http://example.com/ontoNG#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dc11: <http://purl.org/dc/elements/1.1/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

base: a owl:Ontology ;
  dc11:title "Enhancer-Gene-Disease Ontology" ;
  dcterms:description "An ontology modeling enhancers, genes, and diseases, including their relationships and key attributes, as derived from structured data and ER modeling. (Generated by AI)" ;
  owl:versionInfo "0.0.1" ;
  vann:preferredNamespaceUri "http://example.com/ontoNG#" ;
  vann:preferredNamespacePrefix "onto_ng" ;
  owl:versionIRI <http://example.com/ontoNG#0.0.1> .

#################################################################
# Datatype Properties
#################################################################

base:enhancerId a owl:DatatypeProperty ;
  rdfs:label "enhancerId" ;
  skos:definition "A unique identifier for an enhancer. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:string .

base:chromosome a owl:DatatypeProperty ;
  rdfs:label "chromosome" ;
  skos:definition "The chromosome on which the enhancer is located. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:string .

base:startPosition a owl:DatatypeProperty ;
  rdfs:label "startPosition" ;
  skos:definition "The start position of the enhancer on the chromosome. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:integer .

base:endPosition a owl:DatatypeProperty ;
  rdfs:label "endPosition" ;
  skos:definition "The end position of the enhancer on the chromosome. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range xsd:integer .

base:targetGene a owl:DatatypeProperty ;
  rdfs:label "targetGene" ;
  skos:definition "The name or identifier of the gene targeted by the enhancer. (Generated by AI)" ;
  rdfs:domain base:Gene ;
  rdfs:range xsd:string .

base:disease a owl:DatatypeProperty ;
  rdfs:label "disease" ;
  skos:definition "The name or identifier of the disease associated with the gene. (Generated by AI)" ;
  rdfs:domain base:Disease ;
  rdfs:range xsd:string .

#################################################################
# Object Properties
#################################################################

base:targets a owl:ObjectProperty ;
  rdfs:label "targets" ;
  skos:definition "Relates an enhancer to the gene(s) it targets. (Generated by AI)" ;
  rdfs:domain base:Enhancer ;
  rdfs:range base:Gene .

base:associatedWith a owl:ObjectProperty ;
  rdfs:label "associated with" ;
  skos:definition "Relates a gene to the disease(s) it is associated with. (Generated by AI)" ;
  rdfs:domain base:Gene ;
  rdfs:range base:Disease .

#################################################################
# Classes
#################################################################

base:Enhancer a owl:Class ;
  rdfs:label "Enhancer" ;
  skos:definition "A DNA sequence that can increase the transcription of genes, characterized by its genomic location and identifier. (Generated by AI)" ;
  rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty base:enhancerId ;
      owl:someValuesFrom xsd:string
    ] ,
    [ a owl:Restriction ;
      owl:onProperty base:chromosome ;
      owl:someValuesFrom xsd:string
    ] ,
    [ a owl:Restriction ;
      owl:onProperty base:startPosition ;
      owl:someValuesFrom xsd:integer
    ] ,
    [ a owl:Restriction ;
      owl:onProperty base:endPosition ;
      owl:someValuesFrom xsd:integer
    ] ,
    [ a owl:Restriction ;
      owl:onProperty base:targets ;
      owl:someValuesFrom base:Gene
    ] .

base:Gene a owl:Class ;
  rdfs:label "Gene" ;
  skos:definition "A unit of heredity in a living organism, targeted by enhancers and associated with diseases. (Generated by AI)" ;
  rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty base:targetGene ;
      owl:someValuesFrom xsd:string
    ] ,
    [ a owl:Restriction ;
      owl:onProperty base:associatedWith ;
      owl:someValuesFrom base:Disease
    ] .

base:Disease a owl:Class ;
  rdfs:label "Disease" ;
  skos:definition "A disorder or abnormal condition associated with genes. (Generated by AI)" ;
  rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty base:disease ;
      owl:someValuesFrom xsd:string
    ] .