@prefix base: <http://example.com/ontoNG#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gomo: <https://ontology.basf.net/ontology/BASF/Core/GomoMetadata/> .
@prefix term: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix element: <http://purl.org/dc/elements/1.1/> .

base:EnhancerOntology rdf:type owl:Ontology ;
    element:title "Enhancer-Gene-Disease Ontology" ;
    term:description "Ontology modeling enhancers, their genomic locations, target genes, and associated diseases. (Generated by AI)" ;
    element:creator "user@email.com" ;
    term:created "2026-04-10" ;
    term:issued "2026-04-10" ;
    owl:versionInfo "0.0.1" ;
    vann:preferredNamespaceUri "http://example.com/ontoNG#" ;
    vann:preferredNamespacePrefix "base" ;
    owl:versionIRI <http://example.com/ontoNG#0.0.1> .

#################################################################
#    Datatype Properties
#################################################################

base:enhancerId rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:string ;
    rdfs:label "enhancer id" ;
    skos:definition "A unique identifier for an enhancer. (Generated by AI)" .

base:chromosome rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:string ;
    rdfs:label "chromosome" ;
    skos:definition "The chromosome on which the enhancer is located. (Generated by AI)" .

base:startPosition rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:integer ;
    rdfs:label "start position" ;
    skos:definition "The start position of the enhancer on the chromosome. (Generated by AI)" .

base:endPosition rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Enhancer ;
    rdfs:range xsd:integer ;
    rdfs:label "end position" ;
    skos:definition "The end position of the enhancer on the chromosome. (Generated by AI)" .

base:targetGene rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Gene ;
    rdfs:range xsd:string ;
    rdfs:label "target gene" ;
    skos:definition "The name or identifier of the gene targeted by the enhancer. (Generated by AI)" .

base:disease rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Disease ;
    rdfs:range xsd:string ;
    rdfs:label "disease" ;
    skos:definition "The name or identifier of the disease associated with the gene. (Generated by AI)" .

#################################################################
#    Object Properties
#################################################################

base:targets rdf:type owl:ObjectProperty ;
    rdfs:domain base:Enhancer ;
    rdfs:range base:Gene ;
    rdfs:label "targets" ;
    skos:definition "Relates an enhancer to the gene(s) it targets. (Generated by AI)" .

base:associatedWith rdf:type owl:ObjectProperty ;
    rdfs:domain base:Gene ;
    rdfs:range base:Disease ;
    rdfs:label "associated with" ;
    skos:definition "Relates a gene to disease(s) it is associated with. (Generated by AI)" .

#################################################################
#    Classes
#################################################################

base:Enhancer rdf:type owl:Class ;
    rdfs:label "enhancer" ;
    skos:definition "A regulatory DNA sequence that can increase the transcription of genes. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty base:enhancerId ;
          owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty base:chromosome ;
          owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty base:startPosition ;
          owl:someValuesFrom xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty base:endPosition ;
          owl:someValuesFrom xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty base:targets ;
          owl:someValuesFrom base:Gene
        ] .

base:Gene rdf:type owl:Class ;
    rdfs:label "gene" ;
    skos:definition "A segment of DNA that encodes a functional product, typically a protein. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty base:targetGene ;
          owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty base:associatedWith ;
          owl:someValuesFrom base:Disease
        ] .

base:Disease rdf:type owl:Class ;
    rdfs:label "disease" ;
    skos:definition "A disorder or abnormal condition affecting an organism, associated with genes. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty base:disease ;
          owl:someValuesFrom xsd:string
        ] .