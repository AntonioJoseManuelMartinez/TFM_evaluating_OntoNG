@prefix base: <http://example.com/tad-ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gomo: <https://ontology.basf.net/ontology/BASF/Core/GomoMetadata/> .
@prefix term: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix element: <http://purl.org/dc/elements/1.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <https://schema.org/> .

base:TadOntology rdf:type owl:Ontology ;
    element:title "tad ontology" ;
    term:description "An ontology describing topologically associating domains, their genomic coordinates, and observation context including cell type, source method, calling method, resolution, source file, and database. (Generated by AI)" ;
    element:creator "None (user@email.com)" ;
    term:created "2026-04-22"^^xsd:date ;
    term:issued "2026-04-22"^^xsd:date ;
    owl:versionInfo "0.0.1" ;
    vann:preferredNamespaceUri "http://example.com/tad-ontology#" ;
    vann:preferredNamespacePrefix "tad_ontology" ;
    owl:versionIRI <http://example.com/tad-ontology#0.0.1> .

base:callingMethod rdf:type owl:DatatypeProperty ;
    rdfs:label "calling method" ;
    skos:definition "A method name used to call or identify a topologically associating domain observation. (Generated by AI)" ;
    rdfs:domain base:CallingMethod ;
    rdfs:range xsd:string .

base:cellType rdf:type owl:DatatypeProperty ;
    rdfs:label "cell type" ;
    skos:definition "A cell type designation associated with a topologically associating domain observation context. (Generated by AI)" ;
    rdfs:domain base:CellType ;
    rdfs:range xsd:string .

base:chromosome rdf:type owl:DatatypeProperty ;
    rdfs:label "chromosome" ;
    skos:definition "A chromosome identifier on which a topologically associating domain is located. (Generated by AI)" ;
    rdfs:domain base:TAD ;
    rdfs:range xsd:string ;
    rdfs:seeAlso schema:chromosome .

base:databaseName rdf:type owl:DatatypeProperty ;
    rdfs:label "database name" ;
    skos:definition "A database name in which a topologically associating domain observation is stored. (Generated by AI)" ;
    rdfs:domain base:Database ;
    rdfs:range xsd:string .

base:endPosition rdf:type owl:DatatypeProperty ;
    rdfs:label "end position" ;
    skos:definition "The genomic end coordinate of a topologically associating domain. (Generated by AI)" ;
    rdfs:domain base:TAD ;
    rdfs:range xsd:integer .

base:resolution rdf:type owl:DatatypeProperty ;
    rdfs:label "resolution" ;
    skos:definition "A resolution value at which a topologically associating domain observation was generated or reported. (Generated by AI)" ;
    rdfs:domain base:Resolution ;
    rdfs:range xsd:string .

base:sourceFile rdf:type owl:DatatypeProperty ;
    rdfs:label "source file" ;
    skos:definition "A source file identifier recording a topologically associating domain observation. (Generated by AI)" ;
    rdfs:domain base:SourceFile ;
    rdfs:range xsd:string .

base:sourceMethod rdf:type owl:DatatypeProperty ;
    rdfs:label "source method" ;
    skos:definition "A source method describing how topologically associating domain data were derived. (Generated by AI)" ;
    rdfs:domain base:SourceMethod ;
    rdfs:range xsd:string .

base:startPosition rdf:type owl:DatatypeProperty ;
    rdfs:label "start position" ;
    skos:definition "The genomic start coordinate of a topologically associating domain. (Generated by AI)" ;
    rdfs:domain base:TAD ;
    rdfs:range xsd:integer .

base:tadId rdf:type owl:DatatypeProperty ;
    rdfs:label "tad id" ;
    skos:definition "A unique identifier for a topologically associating domain or for a corresponding observation key component. (Generated by AI)" ;
    rdfs:domain base:TAD ;
    rdfs:range xsd:string ;
    rdfs:seeAlso schema:identifier .

base:atResolution rdf:type owl:ObjectProperty ;
    rdfs:label "at resolution" ;
    skos:definition "Relates a topologically associating domain observation to the resolution at which it was reported. (Generated by AI)" ;
    rdfs:domain base:TADObservation ;
    rdfs:range base:Resolution .

base:derivedFromSourceMethod rdf:type owl:ObjectProperty ;
    rdfs:label "derived from source method" ;
    skos:definition "Relates a topologically associating domain observation to the source method from which it was derived. (Generated by AI)" ;
    rdfs:domain base:TADObservation ;
    rdfs:range base:SourceMethod ;
    rdfs:seeAlso term:source .

base:identifiedByCallingMethod rdf:type owl:ObjectProperty ;
    rdfs:label "identified by calling method" ;
    skos:definition "Relates a topologically associating domain observation to the calling method used to identify it. (Generated by AI)" ;
    rdfs:domain base:TADObservation ;
    rdfs:range base:CallingMethod .

base:inCellType rdf:type owl:ObjectProperty ;
    rdfs:label "in cell type" ;
    skos:definition "Relates a topologically associating domain observation to the cell type in which it was made. (Generated by AI)" ;
    rdfs:domain base:TADObservation ;
    rdfs:range base:CellType .

base:observedAs rdf:type owl:ObjectProperty ;
    rdfs:label "observed as" ;
    skos:definition "Relates a topologically associating domain to an observation describing a specific experimental or database context. (Generated by AI)" ;
    rdfs:domain base:TAD ;
    rdfs:range base:TADObservation .

base:recordedInSourceFile rdf:type owl:ObjectProperty ;
    rdfs:label "recorded in source file" ;
    skos:definition "Relates a topologically associating domain observation to the source file in which it is recorded. (Generated by AI)" ;
    rdfs:domain base:TADObservation ;
    rdfs:range base:SourceFile ;
    rdfs:seeAlso schema:isBasedOn .

base:storedInDatabase rdf:type owl:ObjectProperty ;
    rdfs:label "stored in database" ;
    skos:definition "Relates a topologically associating domain observation to the database in which it is stored. (Generated by AI)" ;
    rdfs:domain base:TADObservation ;
    rdfs:range base:Database ;
    rdfs:seeAlso schema:includedInDataCatalog .

base:CallingMethod rdf:type owl:Class ;
    rdfs:label "calling method" ;
    skos:definition "A method used to identify or call topologically associating domains in a dataset. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:callingMethod ;
            owl:someValuesFrom xsd:string
        ] .

base:CellType rdf:type owl:Class ;
    rdfs:label "cell type" ;
    skos:definition "A cell type in which a topologically associating domain observation is made. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:cellType ;
            owl:someValuesFrom xsd:string
        ] ;
    rdfs:seeAlso foaf:Agent .

base:Database rdf:type owl:Class ;
    rdfs:label "database" ;
    skos:definition "A database resource that stores topologically associating domain observations. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:databaseName ;
            owl:someValuesFrom xsd:string
        ] ;
    rdfs:seeAlso schema:DataCatalog .

base:Resolution rdf:type owl:Class ;
    rdfs:label "resolution" ;
    skos:definition "A resolution specification associated with a topologically associating domain observation. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:resolution ;
            owl:someValuesFrom xsd:string
        ] .

base:SourceFile rdf:type owl:Class ;
    rdfs:label "source file" ;
    skos:definition "A source file in which a topologically associating domain observation is recorded. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:sourceFile ;
            owl:someValuesFrom xsd:string
        ] ;
    rdfs:seeAlso schema:MediaObject .

base:SourceMethod rdf:type owl:Class ;
    rdfs:label "source method" ;
    skos:definition "A source method describing how topologically associating domain data were produced or derived. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:sourceMethod ;
            owl:someValuesFrom xsd:string
        ] .

base:TAD rdf:type owl:Class ;
    rdfs:label "tad" ;
    skos:definition "A topologically associating domain defined by genomic coordinates and identifier. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:chromosome ;
            owl:someValuesFrom xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:endPosition ;
            owl:someValuesFrom xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:observedAs ;
            owl:someValuesFrom base:TADObservation
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:startPosition ;
            owl:someValuesFrom xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:tadId ;
            owl:someValuesFrom xsd:string
        ] ;
    rdfs:seeAlso schema:BioChemEntity .

base:TADObservation rdf:type owl:Class ;
    rdfs:label "tad observation" ;
    skos:definition "An observation record describing a topologically associating domain in a specific biological, methodological, file, and database context. (Generated by AI)" ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
            owl:onProperty base:atResolution ;
            owl:someValuesFrom base:Resolution
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:derivedFromSourceMethod ;
            owl:someValuesFrom base:SourceMethod
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:identifiedByCallingMethod ;
            owl:someValuesFrom base:CallingMethod
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:inCellType ;
            owl:someValuesFrom base:CellType
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:recordedInSourceFile ;
            owl:someValuesFrom base:SourceFile
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:storedInDatabase ;
            owl:someValuesFrom base:Database
        ] ,
        [ rdf:type owl:Restriction ;
            owl:onProperty base:tadId ;
            owl:someValuesFrom xsd:string
        ] .