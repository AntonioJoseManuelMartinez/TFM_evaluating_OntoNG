@prefix base: <http://example.com/tad-ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gomo: <https://ontology.basf.net/ontology/BASF/Core/GomoMetadata/> .
@prefix term: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix element: <http://purl.org/dc/elements/1.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <https://schema.org/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

base:TADOntology rdf:type owl:Ontology ;
    element:title "tad ontology" ;
    term:description "An ontology for representing topologically associating domains, their genomic coordinates, provenance, experimental characterization context, and source metadata. (Generated by AI)" ;
    element:creator "None (user@email.com)" ;
    term:created "2026-04-20"^^xsd:date ;
    term:issued "2026-04-20"^^xsd:date ;
    owl:versionInfo "0.0.1" ;
    vann:preferredNamespaceUri "http://example.com/tad-ontology#" ;
    vann:preferredNamespacePrefix "tad_ontology" ;
    owl:versionIRI <http://example.com/tad-ontology#0.0.1> .

base:callingMethod rdf:type owl:DatatypeProperty ;
    rdfs:domain base:CallingMethod ;
    rdfs:range xsd:string ;
    rdfs:label "calling method" ;
    skos:definition "A textual identifier for a calling method used to identify a topologically associating domain. (Generated by AI)" ;
    rdfs:seeAlso schema:name .

base:cellType rdf:type owl:DatatypeProperty ;
    rdfs:domain base:CellType ;
    rdfs:range xsd:string ;
    rdfs:label "cell type" ;
    skos:definition "A textual identifier for a cell type used to characterize a topologically associating domain. (Generated by AI)" ;
    rdfs:seeAlso schema:name .

base:chromosome rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Chromosome ;
    rdfs:range xsd:string ;
    rdfs:label "chromosome" ;
    skos:definition "A textual identifier for a chromosome on which a topologically associating domain is located. (Generated by AI)" ;
    rdfs:seeAlso schema:identifier .

base:databaseName rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Database ;
    rdfs:range xsd:string ;
    rdfs:label "database name" ;
    skos:definition "A textual identifier for a database in which a topologically associating domain is stored. (Generated by AI)" ;
    rdfs:seeAlso schema:name .

base:endPosition rdf:type owl:DatatypeProperty ;
    rdfs:domain base:TAD ;
    rdfs:range xsd:integer ;
    rdfs:label "end position" ;
    skos:definition "The genomic end coordinate of a topologically associating domain. (Generated by AI)" ;
    rdfs:seeAlso schema:endPosition .

base:resolution rdf:type owl:DatatypeProperty ;
    rdfs:domain base:Resolution ;
    rdfs:range xsd:string ;
    rdfs:label "resolution" ;
    skos:definition "A textual identifier for the resolution used to define a topologically associating domain. (Generated by AI)" ;
    rdfs:seeAlso schema:value .

base:sourceFile rdf:type owl:DatatypeProperty ;
    rdfs:domain base:SourceFile ;
    rdfs:range xsd:string ;
    rdfs:label "source file" ;
    skos:definition "A textual identifier for a source file in which a topologically associating domain is recorded. (Generated by AI)" ;
    rdfs:seeAlso schema:name .

base:sourceMethod rdf:type owl:DatatypeProperty ;
    rdfs:domain base:SourceMethod ;
    rdfs:range xsd:string ;
    rdfs:label "source method" ;
    skos:definition "A textual identifier for the source method from which a topologically associating domain is derived. (Generated by AI)" ;
    rdfs:seeAlso schema:name .

base:startPosition rdf:type owl:DatatypeProperty ;
    rdfs:domain base:TAD ;
    rdfs:range xsd:integer ;
    rdfs:label "start position" ;
    skos:definition "The genomic start coordinate of a topologically associating domain. (Generated by AI)" ;
    rdfs:seeAlso schema:startPosition .

base:tadId rdf:type owl:DatatypeProperty ;
    rdfs:domain base:TAD ;
    rdfs:range xsd:string ;
    rdfs:label "tad id" ;
    skos:definition "A textual identifier for a topologically associating domain. (Generated by AI)" ;
    rdfs:seeAlso schema:identifier .

base:characterizes rdf:type owl:ObjectProperty ;
    rdfs:domain base:CellType ;
    rdfs:range base:TAD ;
    rdfs:label "characterizes" ;
    skos:definition "Relates a cell type to a topologically associating domain that it characterizes. (Generated by AI)" .

base:defines rdf:type owl:ObjectProperty ;
    rdfs:domain base:Resolution ;
    rdfs:range base:TAD ;
    rdfs:label "defines" ;
    skos:definition "Relates a resolution to a topologically associating domain that it defines. (Generated by AI)" .

base:derives rdf:type owl:ObjectProperty ;
    rdfs:domain base:SourceMethod ;
    rdfs:range base:TAD ;
    rdfs:label "derives" ;
    skos:definition "Relates a source method to a topologically associating domain that is derived from it. (Generated by AI)" .

base:identifies rdf:type owl:ObjectProperty ;
    rdfs:domain base:CallingMethod ;
    rdfs:range base:TAD ;
    rdfs:label "identifies" ;
    skos:definition "Relates a calling method to a topologically associating domain that it identifies. (Generated by AI)" .

base:locates rdf:type owl:ObjectProperty ;
    rdfs:domain base:Chromosome ;
    rdfs:range base:TAD ;
    rdfs:label "locates" ;
    skos:definition "Relates a chromosome to a topologically associating domain located on it. (Generated by AI)" ;
    owl:inverseOf base:isLocatedOn .

base:isLocatedOn rdf:type owl:ObjectProperty ;
    rdfs:domain base:TAD ;
    rdfs:range base:Chromosome ;
    rdfs:label "is located on" ;
    skos:definition "Relates a topologically associating domain to the chromosome on which it is located. (Generated by AI)" .

base:recordedIn rdf:type owl:ObjectProperty ;
    rdfs:domain base:SourceFile ;
    rdfs:range base:TAD ;
    rdfs:label "recorded in" ;
    skos:definition "Relates a source file to a topologically associating domain recorded in it. (Generated by AI)" ;
    owl:inverseOf base:hasSourceFile .

base:storedIn rdf:type owl:ObjectProperty ;
    rdfs:domain base:Database ;
    rdfs:range base:TAD ;
    rdfs:label "stored in" ;
    skos:definition "Relates a database to a topologically associating domain stored in it. (Generated by AI)" ;
    owl:inverseOf base:hasDatabase .

base:usesCallingMethod rdf:type owl:ObjectProperty ;
    rdfs:domain base:TAD ;
    rdfs:range base:CallingMethod ;
    rdfs:label "uses calling method" ;
    skos:definition "Relates a topologically associating domain to the calling method used to identify it. (Generated by AI)" .

base:usesCellType rdf:type owl:ObjectProperty ;
    rdfs:domain base:TAD ;
    rdfs:range base:CellType ;
    rdfs:label "uses cell type" ;
    skos:definition "Relates a topologically associating domain to the cell type that characterizes it. (Generated by AI)" .

base:usesResolution rdf:type owl:ObjectProperty ;
    rdfs:domain base:TAD ;
    rdfs:range base:Resolution ;
    rdfs:label "uses resolution" ;
    skos:definition "Relates a topologically associating domain to the resolution used to define it. (Generated by AI)" .

base:usesSourceMethod rdf:type owl:ObjectProperty ;
    rdfs:domain base:TAD ;
    rdfs:range base:SourceMethod ;
    rdfs:label "uses source method" ;
    skos:definition "Relates a topologically associating domain to the source method from which it is derived. (Generated by AI)" .

base:hasDatabase rdf:type owl:ObjectProperty ;
    rdfs:domain base:TAD ;
    rdfs:range base:Database ;
    rdfs:label "has database" ;
    skos:definition "Relates a topologically associating domain to the database in which it is stored. (Generated by AI)" .

base:hasSourceFile rdf:type owl:ObjectProperty ;
    rdfs:domain base:TAD ;
    rdfs:range base:SourceFile ;
    rdfs:label "has source file" ;
    skos:definition "Relates a topologically associating domain to the source file in which it is recorded. (Generated by AI)" .

base:CallingMethod rdf:type owl:Class ;
    rdfs:label "calling method" ;
    skos:definition "A method used to identify a topologically associating domain. (Generated by AI)" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:callingMethod ;
        owl:someValuesFrom xsd:string
    ] ;
    rdfs:seeAlso schema:Method .

base:CellType rdf:type owl:Class ;
    rdfs:label "cell type" ;
    skos:definition "A cell type used to characterize a topologically associating domain. (Generated by AI)" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:cellType ;
        owl:someValuesFrom xsd:string
    ] ;
    rdfs:seeAlso schema:MedicalEntity .

base:Chromosome rdf:type owl:Class ;
    rdfs:label "chromosome" ;
    skos:definition "A chromosome that locates a topologically associating domain. (Generated by AI)" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:chromosome ;
        owl:someValuesFrom xsd:string
    ] ;
    rdfs:seeAlso schema:DefinedTerm .

base:Database rdf:type owl:Class ;
    rdfs:label "database" ;
    skos:definition "A database in which a topologically associating domain is stored. (Generated by AI)" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:databaseName ;
        owl:someValuesFrom xsd:string
    ] ;
    rdfs:seeAlso schema:Dataset .

base:Resolution rdf:type owl:Class ;
    rdfs:label "resolution" ;
    skos:definition "A resolution used to define a topologically associating domain. (Generated by AI)" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:resolution ;
        owl:someValuesFrom xsd:string
    ] ;
    rdfs:seeAlso schema:PropertyValue .

base:SourceFile rdf:type owl:Class ;
    rdfs:label "source file" ;
    skos:definition "A source file in which a topologically associating domain is recorded. (Generated by AI)" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:sourceFile ;
        owl:someValuesFrom xsd:string
    ] ;
    rdfs:seeAlso schema:MediaObject .

base:SourceMethod rdf:type owl:Class ;
    rdfs:label "source method" ;
    skos:definition "A source method from which a topologically associating domain is derived. (Generated by AI)" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:sourceMethod ;
        owl:someValuesFrom xsd:string
    ] ;
    rdfs:seeAlso schema:Method .

base:TAD rdf:type owl:Class ;
    rdfs:label "tad" ;
    skos:definition "A topologically associating domain represented by genomic coordinates and linked contextual metadata. (Generated by AI)" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:tadId ;
        owl:someValuesFrom xsd:string
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:startPosition ;
        owl:someValuesFrom xsd:integer
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:endPosition ;
        owl:someValuesFrom xsd:integer
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:isLocatedOn ;
        owl:someValuesFrom base:Chromosome
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:usesSourceMethod ;
        owl:someValuesFrom base:SourceMethod
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:usesCellType ;
        owl:someValuesFrom base:CellType
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:usesCallingMethod ;
        owl:someValuesFrom base:CallingMethod
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:usesResolution ;
        owl:someValuesFrom base:Resolution
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:hasSourceFile ;
        owl:someValuesFrom base:SourceFile
    ] ,
    [
        rdf:type owl:Restriction ;
        owl:onProperty base:hasDatabase ;
        owl:someValuesFrom base:Database
    ] ;
    rdfs:seeAlso schema:BioChemEntity .